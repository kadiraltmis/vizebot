{
  "name": "visa-monitor",
  "version": "1.0.0",
  "description": "Schengen visa appointment slot monitor — detect-only, instant Telegram alerts",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --experimental-sqlite -r dotenv/config dist/index.js",
    "dev": "node --experimental-sqlite --import tsx/esm -r dotenv/config src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chrome-cookies-secure": "^3.0.1",
    "dotenv": "^16.4.5",
    "imapflow": "^1.3.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.9.13",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "playwright": "^1.44.1",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/node-notifier": "^8.0.5",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.15.6",
    "typescript": "^5.9.3"
  }
}
